-- Find internal animal name from display name
local function findAnimalInternalName(displayName)
    for name, data in pairs(Animals) do
        if data.DisplayName == displayName then
            return name
        end
    end
    return nil
end

local function updateList()
    for _, obj in ipairs(buttons) do obj:Destroy() end
    buttons = {}
    selected = nil

    local list = getBrainrots()

    if #list == 0 then
        local lbl = Instance.new("TextLabel", Scroll)
        lbl.Size = UDim2.new(1, -10, 0, 50)
        lbl.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        lbl.Text = "No dupeable brainrots in your plot"
        lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
        lbl.TextSize = 18
        lbl.Font = Enum.Font.Gotham

        local lblCorner = Instance.new("UICorner", lbl)
        lblCorner.CornerRadius = UDim.new(0, 6)

        table.insert(buttons, lbl)
        updateStatus("No targets found in your plot", Color3.fromRGB(255, 200, 100))
    else
        updateStatus(#list .. " brainrots in your plot", Color3.fromRGB(100, 255, 100))

        for i, br in ipairs(list) do
            local btn = Instance.new("TextButton", Scroll)
            btn.Size = UDim2.new(1, -10, 0, 60)
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            btn.Text = ""
            btn.LayoutOrder = i

            local nameLbl = Instance.new("TextLabel", btn)
            nameLbl.Size = UDim2.new(1, -10, 0.5, 0)
            nameLbl.Position = UDim2.new(0, 10, 0, 5)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text = br.name
            nameLbl.TextColor3 = Color3.new(1, 1, 1)
            nameLbl.TextSize = 18
            nameLbl.Font = Enum.Font.GothamBold
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left

            local genLbl = Instance.new("TextLabel", btn)
            genLbl.Size = UDim2.new(1, -10, 0.5, 0)
            genLbl.Position = UDim2.new(0, 10, 0.5, -5)
            genLbl.BackgroundTransparency = 1
            genLbl.Text = br.genText
            genLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
            genLbl.TextSize = 16
            genLbl.Font = Enum.Font.Gotham
            genLbl.TextXAlignment = Enum.TextXAlignment.Left

            local corner = Instance.new("UICorner", btn)
            corner.CornerRadius = UDim.new(0, 8)

            local stroke = Instance.new("UIStroke", btn)
            stroke.Color = Color3.fromRGB(70, 70, 70)
            stroke.Thickness = 1

            btn.MouseButton1Click:Connect(function()
                selected = br
                for _, b in ipairs(buttons) do
                    if b:IsA("TextButton") then
                        b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                    end
                end
                btn.BackgroundColor3 = Color3.fromRGB(80, 160, 80)
                updateStatus("Selected: " .. br.name .. " (" .. br.genText .. ")", Color3.fromRGB(100, 255, 255))
            end)

            table.insert(buttons, btn)
        end
    end

    Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 20)
