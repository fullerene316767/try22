VisualDupeBtn.MouseButton1Click:Connect(function()
    if not selected then
        updateStatus("No brainrot selected!", Color3.fromRGB(255, 100, 100))
        return
    end

    local animalName = findAnimalInternalName(selected.name)
    if not animalName then
        updateStatus("Animal data not found!", Color3.fromRGB(255, 100, 100))
        return
    end

    local traits = getTraitsFromOverhead(selected.overhead)
    local mutation = getMutationFromOverhead(selected.overhead)

    local success, result = spawnAnimal(animalName, traits, mutation == "None" and nil or mutation)

    if success then
        visualDupedBrainrots[selected.key] = true
        updateStatus("SUCCESS: VisualDuped " .. selected.name .. "!", Color3.fromRGB(100, 255, 100))
        task.wait(1)
        updateList()
    else
        updateStatus("Failed: " .. tostring(result), Color3.fromRGB(255, 100, 100))
    end
end)

-- Auto VisualDupe Toggle
AutoVisualDupeToggle.MouseButton1Click:Connect(function()
    autoVisualDupeEnabled = not autoVisualDupeEnabled
    AutoVisualDupeToggle.Text = "AUTO VISUALDUPE: " .. (autoVisualDupeEnabled and "ON" or "OFF")
    AutoVisualDupeToggle.BackgroundColor3 = autoVisualDupeEnabled and Color3.fromRGB(40, 140, 40) or Color3.fromRGB(80, 80, 80)

    if autoVisualDupeEnabled then
        updateStatus("Auto VisualDupe ENABLED - duping highest value", Color3.fromRGB(100, 255, 100))

        autoTask = task.spawn(function()
            while autoVisualDupeEnabled do
                local list = getBrainrots()
                if #list > 0 then
                    local best = list[1]
                    selected = best

                    local animalName = findAnimalInternalName(best.name)
                    if animalName then
                        local traits = getTraitsFromOverhead(best.overhead)
                        local mutation = getMutationFromOverhead(best.overhead)

                        local success = spawnAnimal(animalName, traits, mutation == "None" and nil or mutation)

                        if success then
                            visualDupedBrainrots[best.key] = true
                            updateStatus("Auto-duped: " .. best.name, Color3.fromRGB(100, 255, 100))
                        end
                    end
                else
                    updateStatus("All brainrots duped! Waiting...", Color3.fromRGB(255, 200, 100))
                end
                task.wait(3)
            end
        end)
    else
        updateStatus("Auto VisualDupe disabled", Color3.fromRGB(255, 200, 100))
        if autoTask then autoTask = nil end
    end
end)

