-- BUTTON HELPER
local function makeButton(text, yPos, colorOn, textSize)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 36)
    btn.Position = UDim2.new(0, 10, 0, yPos)
    btn.BackgroundColor3 = colorOn or Color3.fromRGB(35, 35, 48)
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = textSize or 11
    btn.TextColor3 = Color3.fromRGB(220, 220, 240)
    btn.ZIndex = 3
    btn.Parent = MainFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    local s = Instance.new("UIStroke", btn)
    s.Thickness = 1
    s.Color = Color3.fromRGB(55, 50, 80)
    s.Transparency = 0.3

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(
                (colorOn or Color3.fromRGB(35,35,48)).R * 255 + 15,
                (colorOn or Color3.fromRGB(35,35,48)).G * 255 + 15,
                (colorOn or Color3.fromRGB(35,35,48)).B * 255 + 15
            )
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = colorOn or Color3.fromRGB(35, 35, 48)
        }):Play()
    end)

    return btn, s
end

