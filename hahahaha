-- SCROLL ITEM BUILDER (called by your logic)
-- =====================================================

local selected = nil
local buttons = {}

local function clearList()
    for _, obj in ipairs(buttons) do obj:Destroy() end
    buttons = {}
    selected = nil
end

function buildList(list)
    clearList()
    if #list == 0 then
        setStatus("No brainrots found", Color3.fromRGB(255, 180, 80))
        local empty = Instance.new("TextLabel", Scroll)
        empty.Size = UDim2.new(1, 0, 0, 40)
        empty.BackgroundTransparency = 1
        empty.Text = "No brainrots on your base"
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.TextColor3 = Color3.fromRGB(100, 100, 130)
        empty.ZIndex = 4
        table.insert(buttons, empty)
        return
    end

    setStatus(#list .. " brainrot(s) found", Color3.fromRGB(80, 200, 120))

    for _, br in ipairs(list) do
        local item = Instance.new("TextButton", Scroll)
        item.Size = UDim2.new(1, 0, 0, 58)
        item.BackgroundColor3 = Color3.fromRGB(25, 25, 34)
        item.BorderSizePixel = 0
        item.Text = ""
        item.ZIndex = 4
        Instance.new("UICorner", item).CornerRadius = UDim.new(0, 10)

        local iStroke = Instance.new("UIStroke", item)
        iStroke.Thickness = 1
        iStroke.Color = Color3.fromRGB(45, 45, 60)
        iStroke.Transparency = 0.4

        local nameLabel = Instance.new("TextLabel", item)
        nameLabel.Size = UDim2.new(1, -12, 0, 28)
        nameLabel.Position = UDim2.new(0, 10, 0, 6)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = br.name
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 13
        nameLabel.TextColor3 = Color3.fromRGB(220, 220, 245)
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.ZIndex = 5

        local genLabel = Instance.new("TextLabel", item)
        genLabel.Size = UDim2.new(1, -12, 0, 18)
        genLabel.Position = UDim2.new(0, 10, 0, 32)
        genLabel.BackgroundTransparency = 1
        genLabel.Text = br.genText
        genLabel.Font = Enum.Font.Gotham
        genLabel.TextSize = 10
        genLabel.TextColor3 = Color3.fromRGB(80, 200, 120)
        genLabel.TextXAlignment = Enum.TextXAlignment.Left
        genLabel.ZIndex = 5

        item.MouseButton1Click:Connect(function()
            selected = br
            for _, b in ipairs(buttons) do
                if b:IsA("TextButton") then
                    TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(25, 25, 34)}):Play()
                    b:FindFirstChildWhichIsA("UIStroke").Color = Color3.fromRGB(45, 45, 60)
                end
            end
            TweenService:Create(item, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 28, 55)}):Play()
            iStroke.Color = Color3.fromRGB(120, 80, 200)
            iStroke.Transparency = 0
            setStatus("Selected: " .. br.name, Color3.fromRGB(140, 100, 255))
        end)

        table.insert(buttons, item)
    end
end

